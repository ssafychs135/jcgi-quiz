# Bundled study materials: keep the 24 PDFs under site/data/pdfs/ in the repo
# so the static site can hyperlink directly to them. Exclude bulky companion
# archives and the unused 시나공 corpus.
시나공_정처기_기출/
*.zip
*.docx
# Ignore stray PDFs outside the served folder; keep site/data/pdfs/*
*.pdf
!site/data/pdfs/**/*.pdf

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node / build tools (not used here but defensive)
node_modules/

# Local server logs
*.log

# Override global .gitignore_global: the Django/Python template ignores /site,
# but this project's static frontend lives there.
!site/
!site/**
